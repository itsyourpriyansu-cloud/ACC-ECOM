{
  "name": "alemah-payload",
  "version": "1.0.0",
  "description": "Alemah — Premium Home Textiles on Payload CMS",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "npm run migrate:deploy && npm run lint && cross-env NODE_OPTIONS=\"--no-deprecation --max-old-space-size=8000\" next build --webpack && node -e \"require('node:fs').accessSync('.next/BUILD_ID')\"",
    "dev": "cross-env NODE_OPTIONS=--no-deprecation next dev",
    "dev:network": "cross-env NODE_OPTIONS=--no-deprecation next dev -H 0.0.0.0",
    "generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap",
    "generate:types": "cross-env NODE_OPTIONS=--no-deprecation payload generate:types",
    "import:listings": "cross-env NODE_OPTIONS=--no-deprecation tsx src/scripts/import-listings.ts",
    "lint": "cross-env NODE_OPTIONS=--no-deprecation eslint . --max-warnings 0",
    "migrate": "cross-env NODE_OPTIONS=--no-deprecation payload migrate",
    "migrate:deploy": "node scripts/migrate-deploy.mjs",
    "payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
    "seed:demo": "cross-env NODE_OPTIONS=--no-deprecation tsx src/scripts/seed-demo.ts",
    "start": "cross-env NODE_OPTIONS=--no-deprecation next start",
    "test": "npm run test:unit && npm run test:integration && npm run test:e2e",
    "test:unit": "vitest run tests/unit",
    "test:integration": "cross-env NODE_ENV=test vitest run tests/int",
    "test:e2e": "cross-env NODE_ENV=test tsx scripts/seed-auth-e2e.ts && cross-env NODE_ENV=test playwright test tests/e2e/auth.e2e.spec.ts tests/e2e/admin.e2e.spec.ts",
    "test:e2e:legacy": "cross-env NODE_ENV=test playwright test tests/e2e/frontend.e2e.spec.ts",
    "release:check": "npm run build && npm test"
  },
  "dependencies": {
    "@google/genai": "^2.11.0",
    "@payloadcms/admin-bar": "^3.86.0",
    "@payloadcms/db-postgres": "^3.0.0",
    "@payloadcms/db-sqlite": "^3.86.0",
    "@payloadcms/email-nodemailer": "^3.0.0",
    "@payloadcms/live-preview-react": "^3.0.0",
    "@payloadcms/next": "^3.0.0",
    "@payloadcms/plugin-ecommerce": "^3.86.0",
    "@payloadcms/plugin-form-builder": "^3.0.0",
    "@payloadcms/plugin-seo": "^3.0.0",
    "@payloadcms/richtext-lexical": "^3.0.0",
    "@payloadcms/storage-vercel-blob": "^3.86.0",
    "@payloadcms/translations": "^3.0.0",
    "@payloadcms/ui": "^3.0.0",
    "@radix-ui/react-accordion": "^1.2.16",
    "@radix-ui/react-checkbox": "^1.3.7",
    "@radix-ui/react-dialog": "^1.1.19",
    "@radix-ui/react-label": "^2.1.11",
    "@radix-ui/react-select": "^2.3.3",
    "@radix-ui/react-slot": "^1.3.0",
    "@stripe/react-stripe-js": "^6.7.0",
    "@stripe/stripe-js": "^9.9.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "cross-env": "10.1.0",
    "date-fns": "^4.1.0",
    "dotenv": "^16.0.0",
    "embla-carousel-auto-scroll": "^8.6.0",
    "embla-carousel-react": "^8.6.0",
    "geist": "^1.3.0",
    "google-auth-library": "^10.9.1",
    "graphql": "^16.8.2",
    "gsap": "^3.15.0",
    "lenis": "^1.3.25",
    "lucide-react": "^0.400.0",
    "next": "^16.2.11",
    "next-themes": "0.4.6",
    "payload": "^3.0.0",
    "prism-react-renderer": "^2.4.1",
    "qs-esm": "8.0.1",
    "react": "^19.2.8",
    "react-dom": "^19.2.8",
    "react-hook-form": "^7.51.0",
    "sharp": "0.35.3",
    "sonner": "^1.7.2",
    "stripe": "^22.3.1",
    "tailwind-merge": "^3.4.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.0"
  },
  "overrides": {
    "fast-uri": "3.1.4",
    "postcss": "$postcss",
    "sharp": "$sharp"
  },
  "devDependencies": {
    "@next/eslint-plugin-next": "^16.2.11",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4.0.0",
    "@tailwindcss/typography": "^0.5.19",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^9.16.0",
    "eslint-config-next": "^16.2.11",
    "postcss": "^8.4.38",
    "prettier": "^3.4.2",
    "tailwindcss": "^4.0.0",
    "tsx": "4.22.4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.0.0",
    "vitest": "^4.1.10"
  }
}
