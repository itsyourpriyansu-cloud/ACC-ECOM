# Production configuration for https://acc-ecom.vercel.app
#
# Add these values in Vercel: Project -> Settings -> Environment Variables.
# Do not upload this file with real values and do not expose DATABASE_URL,
# PAYLOAD_SECRET, or any provider secret to the browser.

# Generate a new 32+ byte random value, for example: openssl rand -base64 48
PAYLOAD_SECRET=replace-with-a-long-random-production-secret

# Supabase: Dashboard -> Connect -> Transaction pooler (port 6543).
# Vercel functions are short-lived and may scale horizontally, so use the
# transaction pooler and keep the local application pool small. Copy the exact URI from Supabase instead of editing
# this example by hand; it includes the correct project-specific username.
DATABASE_URL=postgresql://postgres.PROJECT_REF:SUPABASE_DATABASE_PASSWORD@aws-REGION.pooler.supabase.com:6543/postgres?sslmode=require&uselibpqcompat=true
# Payload reserves one connection while it initializes; keep at least two.
DATABASE_POOL_MAX=3
# Supabase poolers can hold migration locks during Vercel builds. Keep this true
# after applying migrations with `npm run migrate` from a trusted environment.
SKIP_BUILD_MIGRATIONS=true

# The public URL must exactly match the Vercel production domain.
PAYLOAD_PUBLIC_SERVER_URL=https://acc-ecom.vercel.app
NEXT_PUBLIC_SERVER_URL=https://acc-ecom.vercel.app
NEXT_PUBLIC_APP_URL=https://acc-ecom.vercel.app
APP_URL=https://acc-ecom.vercel.app
PREVIEW_SECRET=replace-with-a-separate-long-random-preview-secret

# Required to persist Payload media uploads on Vercel.
BLOB_READ_WRITE_TOKEN=

# Payload's built-in user endpoints (/api/users/login, /api/users/me, etc.)
# use the Supabase Postgres database above. No Supabase browser key is needed.

# Set to true only after the Google OAuth redirect URI below is registered:
# https://acc-ecom.vercel.app/api/auth/google/callback
NEXT_PUBLIC_GOOGLE_AUTH_ENABLED=false
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://acc-ecom.vercel.app/api/auth/google/callback
AUTH_SESSION_SECRET=replace-with-a-separate-long-random-session-secret
AUTH_COOKIE_DOMAIN=
# Optional one-time bootstrap. Remove after the first administrator exists.
BOOTSTRAP_ADMIN_EMAIL=

# Configure to enable password-reset and order email.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM_ADDRESS=orders@acc-ecom.vercel.app
SMTP_FROM_NAME=Alemah

# Leave optional integrations disabled until their server credentials are set.
NEXT_PUBLIC_PHONEPE_ENABLED=false
PHONEPE_CLIENT_ID=
PHONEPE_CLIENT_SECRET=
PHONEPE_CLIENT_VERSION=1
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash

ALLOW_DEMO_SEED=false
ALLOW_CATALOGUE_IMPORT=false
