PAYLOAD_SECRET=replace-with-a-long-random-secret
# Development falls back to SQLite. Production requires a managed PostgreSQL URL.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/alemah
DATABASE_POOL_MAX=20
# Required for persistent Payload uploads when deployed to Vercel. Create a Vercel Blob store to obtain this token.
BLOB_READ_WRITE_TOKEN=

COMPANY_NAME="Alemah"
SITE_NAME="Alemah"

PAYLOAD_PUBLIC_SERVER_URL=http://localhost:3000
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Used to preview drafts
PREVIEW_SECRET=demo-draft-secret

# PhonePe Standard Checkout (sandbox first, production only after approval)
PHONEPE_ENV=sandbox
PHONEPE_CLIENT_ID=
PHONEPE_CLIENT_SECRET=
PHONEPE_CLIENT_VERSION=1
# This only controls whether the customer payment button is available. Set true after the server credentials are configured.
NEXT_PUBLIC_PHONEPE_ENABLED=false

# Transactional email (required in production)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM_ADDRESS=orders@example.com
SMTP_FROM_NAME=Alemah

# Provider credentials — add in Vercel, never commit real values.
SHIPROCKET_EMAIL=
SHIPROCKET_PASSWORD=
SHIPROCKET_PICKUP_LOCATION=
SHIPROCKET_DEFAULT_WEIGHT_KG=0.5
SHIPROCKET_PACKAGE_LENGTH_CM=30
SHIPROCKET_PACKAGE_BREADTH_CM=20
SHIPROCKET_PACKAGE_HEIGHT_CM=8
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# This value is safe to expose and is used only for optimized Cloudinary image URLs.
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Enable after the Google OAuth web application has this exact redirect URI:
# http://localhost:3000/auth/google/callback (development)
# https://your-domain.com/auth/google/callback (production)
NEXT_PUBLIC_GOOGLE_AUTH_ENABLED=false
# Optional one-time bootstrap. Only this email can become the first admin.
BOOTSTRAP_ADMIN_EMAIL=

# Optional server-only AI intent extraction. The guided product finder still works when these are empty.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash

# Keep false on a live store. It permits the idempotent demo catalogue seed only.
ALLOW_DEMO_SEED=false
ALLOW_CATALOGUE_IMPORT=false
